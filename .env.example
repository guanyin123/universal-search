# —— 保存目录（可选）——
# 报告/工作流默认保存到这里。留空则在应用「设置」里指定（推荐）。
# VAULT_ROOT=/absolute/path/to/your/notes
# —— LLM ——
# 模型在应用内「设置 → 管理渠道」里配置（base_url + 密钥 + 模型），无需在此填写。
# 下面几项仅作首次启动的可选种子；公开版默认留空，启动后由新手向导引导配置。
LLM_BASE_URL=
LLM_API_KEY=
FANOUT_MODEL=
SYNTH_MODEL=
# 可选：当 provider 的 /models 不可用时，作为 UI 选择器的模型兜底清单（逗号分隔）。
LLM_MODELS=
# —— Search ——
TAVILY_API_KEY=tvly-...
# Optional: enables the "他人写作 / People's Writing" dimension (Exa neural search).
# Leave blank to hide that dimension — Web search still works.
EXA_API_KEY=
# Optional: enables the "社区与网站 / Communities & Sites" dimension — a ranked,
# named target picker (subreddits + websites + Hacker News), scored by real metrics
# (Reddit subscribers · Tranco domain rank). Set to true to opt in.
COMMUNITY_ENABLED=
# Optional: Reddit app-only OAuth. Keyless www.reddit.com/*.json is 403-blocked from
# data-center IPs; set both to route subreddit scoring + search through
# oauth.reddit.com. Create a free "web app" at https://www.reddit.com/prefs/apps
# (redirect URI can be http://localhost) — use its client id + secret. Leave blank to
# use the keyless path (works from residential IPs; subreddits drop out otherwise).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional: enables the "图片 / Images" dimension (Unsplash). Get a free Access Key
# at https://unsplash.com/developers. Leave blank to hide that dimension.
UNSPLASH_ACCESS_KEY=
JINA_API_KEY=
