{
	"name": "universal-search",
	"private": true,
	"version": "0.0.1",
	"description": "Local research tool — ask a question, edit an AI-proposed multi-source search plan, synthesize a report, and deposit it into your Obsidian vault.",
	"type": "module",
	"license": "Apache-2.0",
	"author": "guanyin",
	"homepage": "https://github.com/guanyin123/universal-search#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/guanyin123/universal-search.git"
	},
	"bugs": {
		"url": "https://github.com/guanyin123/universal-search/issues"
	},
	"keywords": [
		"research",
		"search",
		"obsidian",
		"knowledge-management",
		"sveltekit",
		"ai",
		"llm",
		"tavily"
	],
	"engines": {
		"node": ">=22.5.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "node build",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.9.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@ai-sdk/openai-compatible": "^2.0.51",
		"@phosphor-icons/web": "^2.1.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"ai": "^6.0.207",
		"dompurify": "^3.4.11",
		"marked": "^18.0.5",
		"simple-git": "^3.36.0"
	}
