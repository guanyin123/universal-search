# Dependencies & build output (rebuilt inside the image)
node_modules
.svelte-kit
build

# VCS & CI
.git
.gitignore
.github

# Local runtime state — never bake into the image (mount as volumes instead)
.data
.runs

# Secrets & local env
.env
.env.*
!.env.example

# Docs, design assets, editor cruft — not needed to build the app
docs
design
*.md
.vscode
.idea
.DS_Store
Thumbs.db
coverage
npm-debug.log*
